{
  "version": 2,
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "fe/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "app/main.py"
    },
    {
      "src": "/login",
      "dest": "fe/index.html"
    },
    {
      "src": "/admin/key",
      "dest": "fe/index.html"
    },
    {
      "src": "/",
      "dest": "fe/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "fe/$1"
    }
  ]
}
