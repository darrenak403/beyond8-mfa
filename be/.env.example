APP_NAME=your_app_name
API_PREFIX=/api

# Supabase Postgres (Pooled connection string, sslmode=require)
DATABASE_URL=postgresql+psycopg2://postgres.uyhzaxldnpvodqafgzct:

# JWT dùng cho auth-token và beyond-course-access token
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ALGORITHM=HS256
COURSE_ACCESS_TOKEN_EXPIRE_DAYS=30

# OTP settings
KEY_PREFIX=xxx
OTP_TTL_SECONDS=60
OTP_REFRESH_COOLDOWN_SECONDS=60

# Admin account is seeded automatically as admin@gmail.com

# CORS cho local + domain deploy Vercel
CORS_ORIGINS=your_cors_origins

