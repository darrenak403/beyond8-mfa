APP_NAME=your_app_name
API_PREFIX=/api
EXPOSE_API_DOCS=false
# Chỉ bạn mở được Swagger: đặt cả hai; không cần bật EXPOSE_API_DOCS công khai.
# DOCS_BASIC_AUTH_USER=you
# DOCS_BASIC_AUTH_PASSWORD=strong-random-secret

# Postgres connection string (sslmode=require when needed)
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/database

# JWT dùng cho auth-token và beyond-course-access token
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ALGORITHM=HS256
COURSE_ACCESS_TOKEN_EXPIRE_DAYS=30

# OTP settings
# Redis key namespace for all cache keys
KEY_PREFIX=xxx
OTP_TTL_SECONDS=60
OTP_REFRESH_COOLDOWN_SECONDS=60

# Admin account is seeded automatically as admin@gmail.com

# CORS cho local + domain deploy Vercel
CORS_ORIGINS=your_cors_origins

REDIS_ENABLED=true
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token